from datetime import datetime
def time_delta(t1, t2):
    fmt='%a %d %b %Y %H:%M:%S %z'
    dt1=datetime.strptime(t1,fmt)
    dt2=datetime.strptime(t2,fmt)
    return str(int(abs((dt1 - dt2).total_seconds())))
t = int(input()) 
for _ in range(t):
    time1=input()
    time2=input()
    print(time_delta(time1, time2))
