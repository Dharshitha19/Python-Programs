if __name__ == '__main__':
    students=[]
    for _ in range(int(input())):
        name=input()
        score=float(input())
        students.append([name, score])
    unique_s = sorted(set([student[1] for student in students]))
    second_lowest=unique_s[1]
    second_lowest=[student[0] for student in students if student[1] == second_lowest]
    for student_name in sorted(second_lowest):
        print(student_name)
